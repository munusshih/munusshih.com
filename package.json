{
  "name": "munusshih.com",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "prepare:dev": "node scripts/prepareDev.js --quiet",
    "prepare:dev:force": "node scripts/prepareDev.js --force",
    "prepare:build": "npm run sync:yml && npm run cache:teaching-media && npm run cache:homepage-media && npm run generatePoster && npm run generate:og -- --force && npm run sync:work-assets",
    "prepare:build:force": "npm run sync:yml && npm run cache:teaching-media -- --force && npm run cache:homepage-media -- --force && npm run generatePoster && npm run generate:og -- --force && npm run sync:work-assets",
    "dev": "npm run prepare:dev && astro dev",
    "dev:instant": "npm run sync:work-assets && astro dev",
    "generatePoster": "node generatePosters.js",
    "generate:og": "node scripts/generateOgImages.js",
    "cache:teaching-media": "node scripts/cacheTeachingMedia.js",
    "cache:homepage-media": "node scripts/cacheHomepageMedia.js",
    "sync:yml": "node scripts/updateYamlFromSheets.js",
    "sync:work-assets": "node scripts/syncWorkAssets.js",
    "build": "npm run prepare:build && astro build",
    "build:force": "npm run prepare:build:force && astro build",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.3.1",
    "@astrojs/rss": "^4.0.12",
    "@astrojs/sitemap": "^3.4.2",
    "@astrojs/vercel": "^8.2.3",
    "@barba/core": "^2.10.3",
    "@tailwindcss/vite": "^4.1.3",
    "astro": "^5.12.4",
    "astro-loading-indicator": "^0.7.0",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "gsap": "^3.12.7",
    "interactjs": "^1.10.27",
    "lenis": "^1.2.3",
    "marked": "^15.0.8",
    "p5": "^1.11.3",
    "playwright": "^1.52.0",
    "swiper": "^11.2.6"
  },
  "devDependencies": {
    "@rollup/plugin-yaml": "^4.1.2",
    "@tailwindcss/typography": "^0.5.16",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.22.0",
    "eslint-plugin-astro": "^1.3.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "js-yaml": "^4.1.0",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "prettier-plugin-astro": "0.14.1",
    "prettier-plugin-css-order": "^2.1.2",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "tailwindcss": "^4.1.4",
    "video.js": "^8.22.0"
  }
}
