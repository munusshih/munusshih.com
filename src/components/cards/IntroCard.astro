---
const {
  size,
  background,
  textColor,
  variant,
  body,
  linkContent,
  linkLabel,
  linkHref,
} = Astro.props;
import DraggableCard from "@/components/global/DraggableCard.astro";
import HeroSketch from "@/components/global/HeroSketch.astro";
import { SITE_DESCRIPTION } from "../../consts";

const cardBackground = background ?? "black";
const cardTextColor = textColor ?? "white";
const hasBody = typeof body === "string" && body.trim().length > 0;
const introBody = hasBody
  ? body
  : variant === "trinity"
    ? ""
    : SITE_DESCRIPTION;
const hasCustomHref = Boolean(linkHref);
const introLinkHref = linkHref || "/about";
const introLinkLabel =
  linkContent ||
  linkLabel ||
  (hasCustomHref ? "Learn more" : "Learn more about me");
---

<DraggableCard>
  <div
    class={`${size} home-card flex aspect-square flex-col p-4 `}
    style={`background: ${cardBackground}; color: ${cardTextColor};`}
  >
    <a href={introLinkHref} class="linkout body2">{introLinkLabel}</a>
    <div class="mt-4 flex min-h-0 flex-1 flex-col gap-3">
      {
        variant === "trinity" ? (
          <div class="trinity-wrapper">
            <div
              class="trinity-canvas"
              data-trinity-sketch
              role="img"
              aria-label="Software, Commons, Community and Munus relationship diagram"
            />
          </div>
        ) : (
          <HeroSketch />
        )
      }
      {introBody && <p class="body1 shrink-0 text-balance">{introBody}</p>}
    </div>
  </div>
  <style>
    .trinity-wrapper {
      flex: 1 1 auto;
      margin-inline: 0;
      width: 100%;
      height: 100%;
      min-height: 0;
      overflow: hidden;
    }

    .trinity-canvas {
      background: transparent;
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }

    .trinity-canvas :global(canvas) {
      display: block;
      max-width: none;
      max-height: none;
      margin-inline: auto;
      width: 100% !important;
      height: auto !important;
    }
  </style>
</DraggableCard>
{variant === "trinity" && <script src="../../scripts/trinityDiagram.js" />}
