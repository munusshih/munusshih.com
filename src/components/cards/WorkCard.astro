---
const {
  size,
  title,
  linkContent,
  work,
  href,
  targetName,
  body,
  description,
  iframe,
  background,
  textColor,
} = Astro.props;
import DraggableCard from "@/components/global/DraggableCard.astro";
import Media from "@/components/utils/Media.astro";
import Iframe from "@/components/utils/Iframe.astro";
import Swiper from "@/components/utils/Swiper.astro";
import { getLabEntries } from "@/data/contentSources.js";
import { marked } from "marked";

let finalContent;

const labEntries = await getLabEntries();

const cardBackground = background ?? "transparent";
const cardTextColor = textColor ?? "inherit";

if (href === "lab") {
  finalContent = labEntries.find((item) => item.image === targetName);
} else {
  finalContent = work;
}

const mediaSourceRaw = finalContent?.image || targetName;
const mediaSource =
  typeof mediaSourceRaw === "string"
    ? mediaSourceRaw.replace(/\[(?:video|image|dark)\]/gi, "").trim()
    : mediaSourceRaw;
const mediaIsVideo =
  typeof mediaSource === "string" &&
  /\.(mp4|webm|ogg|mov|m4v)(?:$|[?#])/i.test(mediaSource);
const mediaWrapperClass = mediaIsVideo
  ? "w-full p-0 shadow"
  : "w-full p-0 shadow aspect-[4/3] overflow-hidden";
const mediaFit = mediaIsVideo ? "contain" : "cover";
const mediaScale = mediaIsVideo ? 1 : 1.03;
const mediaClassName = mediaIsVideo ? "" : "h-full";

const headingLabel = linkContent || title || "";
const panelText = finalContent?.description || body || description || "";
const panelHtml = panelText ? marked.parse(panelText) : "";
const hasCustomBackground =
  typeof background === "string" &&
  background.trim().length > 0 &&
  background.trim().toLowerCase() !== "transparent";
const cardStyle = `color: ${cardTextColor};`;
const panelClass = hasCustomBackground
  ? "code p-4"
  : "code bg-white p-4 text-black";
const panelStyle = hasCustomBackground
  ? `background: ${cardBackground}; color: ${cardTextColor};`
  : undefined;
---

<DraggableCard>
  <div
    class={`home-card flex h-auto ${size} flex-col justify-between`}
    style={cardStyle}
  >
    {
      headingLabel && (
        <h2 class="body2 w-max bg-black p-2 text-white">
          {href ? (
            <a href={href} class="linkout">
              {headingLabel}
            </a>
          ) : (
            headingLabel
          )}
        </h2>
      )
    }
    {
      iframe ? (
        <Iframe src={iframe} title={description || ""} />
      ) : Array.isArray(targetName) ? (
        <Swiper images={targetName} />
      ) : (
        mediaSource && (
          <div class={mediaWrapperClass}>
            <Media
              src={mediaSource}
              alt={finalContent?.description || description || ""}
              isVideo={mediaIsVideo}
              usePoster={false}
              fit={mediaFit}
              scaling={mediaScale}
              className={mediaClassName}
              cropped={true}
            />
          </div>
        )
      )
    }

    {
      panelHtml && (
        <div class={panelClass} style={panelStyle}>
          <div class="custom-body text-balance" set:html={panelHtml} />
        </div>
      )
    }
  </div>
</DraggableCard>
