---
import Media from "@/components/utils/Media.astro";
import Iframe from "@/components/utils/Iframe.astro";
import { externalLinkAttrs } from "@/utils/externalLinks.js";
const { title, description, tags, href, image, imageAlt } = Astro.props;
---

<div class="fade-in flex w-auto flex-col" data-tags={tags?.join(",")}>
  <div class="w-full">
    {
      image &&
        (href ? (
          <a href={href} class="group no-before-after" {...externalLinkAttrs(href)}>
            <Media
              src={image}
              alt={description}
              isVideo={image.match(/\.(mp4|webm|ogg)$/i)}
              cropped={true}
            />
          </a>
        ) : (
          <Media
            src={image}
            alt={description}
            isVideo={image.match(/\.(mp4|webm|ogg)$/i)}
            cropped={true}
          />
        ))
    }

    <p class="code mt-2 text-gray-400">{description}</p>
  </div>
</div>
