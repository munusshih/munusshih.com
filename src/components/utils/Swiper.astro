---
// Swiper.astro
const { images, width = "75%" } = Astro.props;
import "swiper/css";
import Media from "@/components/utils/Media.astro";
---

<div class="swiper" style={`--swiper-slide-width: ${width}`}>
  <div class="swiper-wrapper">
    {
      images.map((src, idx) => {
        const [mediaSrcRaw, scaling] = Array.isArray(src) ? src : [src];
        const mediaSrc =
          typeof mediaSrcRaw === "string"
            ? mediaSrcRaw.replace(/\[(?:video|image|dark)\]/gi, "").trim()
            : mediaSrcRaw;
        const isExplicitVideoTag =
          typeof mediaSrcRaw === "string" && /\[video\]/i.test(mediaSrcRaw);
        const isVideo =
          isExplicitVideoTag ||
          (typeof mediaSrc === "string" &&
            /\.(mp4|webm|ogg|mov|m4v)(?:$|[?#])/i.test(mediaSrc));
        return (
          <div key={idx} class="swiper-slide h-auto">
            <Media
              src={mediaSrc}
              alt={images.src || ""}
              isVideo={isVideo}
              scaling={scaling}
              usePoster={false}
            />
          </div>
        );
      })
    }
  </div>
</div>

<script>
  import Swiper from "swiper";
  import { Autoplay } from "swiper/modules";
  import "swiper/css";

  function initSwiper() {
    const containers = document.querySelectorAll(".swiper");
    containers.forEach((container) => {
      if (!(container instanceof HTMLElement)) return;
      if (container.swiper && !container.swiper.destroyed) return;

      new Swiper(container, {
        modules: [Autoplay],
        slidesPerView: "auto",
        spaceBetween: 10,
        grabCursor: true,
        autoplay: {
          delay: 10000,
          disableOnInteraction: true,
        },
      });
    });
  }

  initSwiper();

  document.addEventListener("astro:page-load", () => {
    initSwiper();
  });
</script>

<style>
  .swiper-slide {
    display: flex;
    background: lightgray;
    aspect-ratio: 4/3;
    width: var(--swiper-slide-width);
    overflow: hidden;
  }
</style>
