---
// Media.astro
const {
  src,
  alt,
  isVideo = false,
  scaling = 1,
  cropped = false,
  className = "",
  widthAuto = false,
  fadeIn = true,
} = Astro.props;
import { normalizeMediaSrc, posterFromMediaSrc } from "@/scripts/mediaPath.js";
const resolvedSrc = normalizeMediaSrc(src);
const posterSrc = posterFromMediaSrc(resolvedSrc);
const fadeClass = fadeIn ? "fade-in" : "";
---

{
  isVideo ? (
    <video
      preload="auto"
      src={resolvedSrc}
      poster={posterSrc || undefined}
      autoplay
      loop
      muted
      playsinline
      webkit-playsinline
      class={`${fadeClass} media *:h-auto ${widthAuto ? "w-auto" : "w-full"} object-cover ${cropped ? "[clip-path:inset(-3px)]" : ""} ${className}`}
      style={{ transform: `scale(${scaling})` }}
      alt={alt}
    >
      Your browser does not support the video tag.
    </video>
  ) : (
    <img
      src={resolvedSrc}
      alt={alt}
      loading="lazy"
      decoding="async"
      class={`${fadeClass} media h-auto ${widthAuto ? "w-auto" : "w-full"} object-cover ${cropped ? "[clip-path:inset(-3px)]" : ""} ${className}`}
    />
  )
}
