---
import BasicLayout from "@/layouts/Basic.astro";
import IntroCard from "@/components/cards/IntroCard.astro";
import WorkCard from "@/components/cards/WorkCard.astro";
import MediaCard from "@/components/cards/MediaCard.astro";
import ListCard from "@/components/cards/ListCard.astro";
import CustomCard from "@/components/cards/CustomCard.astro";
import InstagramCard from "@/components/cards/InstagramCard.astro";
import LinkCard from "@/components/cards/LinkCard.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "@/consts";
import { getHomepageEntries } from "@/data/contentSources.js";
import homepageMedia from "@/data/generated/homepageMedia.json" assert { type: "json" };
import {
  homepageEntryKey,
  isHomepageEntryEnabled,
  resolveHomepageBody,
  resolveHomepageTitle,
  parseMediaList,
} from "@/data/homepageUtils.js";

const homepageEntries = await getHomepageEntries();

const cards = Array.isArray(homepageEntries)
  ? homepageEntries.filter(
      (entry) => entry?.type && isHomepageEntryEnabled(entry),
    )
  : [];

function normaliseWorkTarget(value) {
  if (Array.isArray(value)) return value;
  if (typeof value !== "string") return undefined;

  try {
    const parsed = JSON.parse(value);
    if (Array.isArray(parsed)) return parsed;
  } catch (error) {
    // ignore JSON parse errors
  }

  const delimiters = ["|", "\n", ","];
  const delimiter = delimiters.find((sep) => value.includes(sep));
  if (delimiter) {
    return value
      .split(delimiter)
      .map((item) => item.trim())
      .filter(Boolean);
  }

  const trimmed = value.trim();
  return trimmed.length > 0 ? trimmed : undefined;
}

function getHomepageCachedAssets(entry) {
  const manifestKey = homepageEntryKey(entry);
  if (!manifestKey) return [];
  const manifestEntry = homepageMedia?.[manifestKey];
  return Array.isArray(manifestEntry?.assets) ? manifestEntry.assets : [];
}

function fallbackAssets(value) {
  return parseMediaList(value)
    .filter((src) =>
      /\.(mp4|webm|ogg|mov|m4v|jpe?g|png|gif|webp|avif|svg)(?:$|[?#])/i.test(
        src,
      ),
    )
    .map((src) => ({
      kind: /\.(mp4|webm|ogg|mov|m4v)(?:$|[?#])/i.test(src) ? "video" : "image",
      src,
      source: "targetName",
    }));
}

function resolveInstagramUsername(entry) {
  const direct = String(
    entry.instagramUsername || entry.username || entry.handle || "",
  )
    .trim()
    .replace(/^@/, "");
  if (direct) return direct;

  const href = entry.href || entry.link?.href || "";
  if (!href) return "";

  try {
    const parsed = new URL(href);
    if (!parsed.hostname.toLowerCase().includes("instagram.com")) return "";
    return parsed.pathname.split("/").filter(Boolean)[0] || "";
  } catch (_error) {
    return "";
  }
}

function resolveHref(entry) {
  return entry.href || entry.link?.href || undefined;
}
---

<BasicLayout
  title={SITE_TITLE}
  description={SITE_DESCRIPTION}
  image={`/assets/og/pages/index.jpg`}
>
  <main
    class="fade-in relative grid h-auto w-full grid-cols-1 items-center justify-items-center gap-y-[8vw] overflow-hidden p-[var(--page-margin)] py-20 sm:grid-cols-2"
  >
    <h1
      class="responsive-title fixed top-10 -z-10 w-full self-center leading-tight -tracking-[.095em] sm:absolute"
    >
      <span>Solidarity</span>
      <span>Identity</span>
      <span>Commons</span>
      <span>Publishing</span>
      <span>Writing</span>
      <span>Coding</span>
      <span>Making</span>
      <span>And</span>
      <span>More</span>
    </h1>

    {
      cards.map((entry, index) => {
        const type = entry.type?.toLowerCase?.() || "";
        const key = entry.order ?? index;
        const entryTitle = resolveHomepageTitle(entry);
        const entryBody = resolveHomepageBody(entry);
        const entryHref = resolveHref(entry);

        if (["introcard", "intro"].includes(type)) {
          return (
            <IntroCard
              key={key}
              size={entry.size || "x2-card"}
              background={entry.background}
              textColor={entry.textColor}
              variant={entry.variant}
              body={entryBody}
              linkContent={entry.linkContent || entryTitle || entry.linkLabel}
              linkLabel={entry.linkLabel}
              linkHref={entryHref}
            />
          );
        }

        if (["listcard", "list"].includes(type)) {
          const listTitle = entryTitle || entry.heading || entry.listTitle;
          if (!listTitle) return null;
          return (
            <ListCard
              key={key}
              title={listTitle}
              background={entry.background}
              textColor={entry.textColor}
              body={entryBody}
            />
          );
        }

        if (["workcard", "work"].includes(type)) {
          const target = normaliseWorkTarget(entry.targetName);
          return (
            <WorkCard
              key={key}
              size={entry.size || "x2-card"}
              href={entryHref}
              title={entryTitle}
              linkContent={entry.linkContent || entryTitle || ""}
              targetName={target}
              body={entryBody}
              description={entry.description || entryBody}
              iframe={entry.iframe}
              background={entry.background}
              textColor={entry.textColor}
            />
          );
        }

        if (["mediacard", "media"].includes(type)) {
          const target = Array.isArray(entry.targetName)
            ? entry.targetName[0]
            : entry.targetName;
          return (
            <MediaCard
              key={key}
              size={entry.size || "x1-card"}
              title={entryTitle}
              targetName={target}
              description={entry.description || entryBody}
              iframe={entry.iframe}
              height={entry.height}
              background={entry.background}
              textColor={entry.textColor}
            />
          );
        }

        if (["customcard", "custom"].includes(type)) {
          const target = Array.isArray(entry.targetName)
            ? entry.targetName[0]
            : entry.targetName;
          return (
            <CustomCard
              key={key}
              size={entry.size || "x2-card"}
              title={entryTitle}
              body={entryBody}
              background={entry.background}
              textColor={entry.textColor}
              linkHref={entryHref}
              linkContent={entry.linkContent || entryTitle}
              linkLabel={entry.linkLabel}
              targetName={target}
              iframe={entry.iframe}
              height={entry.height}
            />
          );
        }

        if (["instagramcard", "instagram"].includes(type)) {
          const cachedAssets = getHomepageCachedAssets(entry);
          const targetAssets = fallbackAssets(entry.targetName);
          const mediaItems = cachedAssets.length ? cachedAssets : targetAssets;
          const username = resolveInstagramUsername(entry);
          return (
            <InstagramCard
              key={key}
              size={entry.size || "x2-card"}
              title={entryTitle}
              body={entryBody}
              background={entry.background}
              textColor={entry.textColor}
              href={entryHref}
              linkContent={entry.linkContent || entryTitle}
              linkLabel={entry.linkLabel}
              targetName={entry.targetName}
              mediaItems={mediaItems}
              username={username}
            />
          );
        }

        if (["linkcard", "link"].includes(type)) {
          const cachedAssets = getHomepageCachedAssets(entry);
          const targetAssets = fallbackAssets(entry.targetName);
          const previewAsset =
            cachedAssets[0] ||
            targetAssets[0] ||
            (entry.ogImage
              ? {
                  kind: /\.(mp4|webm|ogg|mov|m4v)(?:$|[?#])/i.test(
                    entry.ogImage,
                  )
                    ? "video"
                    : "image",
                  src: entry.ogImage,
                  source: "ogImage",
                }
              : null);

          return (
            <LinkCard
              key={key}
              size={entry.size || "x2-card"}
              title={entryTitle}
              body={entryBody}
              description={entry.description || entryBody}
              background={entry.background}
              textColor={entry.textColor}
              href={entryHref}
              linkContent={entry.linkContent || entryTitle}
              linkLabel={entry.linkLabel}
              targetName={entry.targetName}
              previewAsset={previewAsset}
            />
          );
        }

        return null;
      })
    }
  </main>
</BasicLayout>
<script>
  import { gsap } from "gsap";

  class ParallaxEffect {
    constructor(cardsSelector) {
      this.cards = document.querySelectorAll(cardsSelector);
      this.cardOffsets = [];
      this.isThrottled = false;

      // Bind methods once to preserve references
      this.boundCheckScreenSize = this.checkScreenSize.bind(this);
      this.boundThrottleParallax = this.throttleParallax.bind(this);

      this.init();
    }

    init() {
      this.checkScreenSize(); // Setup on load
      window.addEventListener("resize", this.boundCheckScreenSize);
    }

    cardOffset() {
      this.cardOffsets = []; // Clear previous offsets to avoid duplication
      this.cards.forEach((div, index) => {
        const randX =
          index % 3 === 2 ? Math.random() * -10 : Math.random() * 20;
        const randY = index % 2 === 0 ? Math.random() * 40 : Math.random() * 20;

        this.cardOffsets.push({ randX, randY });

        gsap.set(div, {
          xPercent: randX,
          yPercent: randY,
          duration: 0.5,
          ease: "power2.out",
        });
      });
    }

    throttleParallax(e) {
      if (this.isThrottled) return;

      this.isThrottled = true;
      requestAnimationFrame(() => this.parallax(e));
      setTimeout(() => {
        this.isThrottled = false;
      }, 16); // ~60 FPS
    }

    parallax(e) {
      const { clientX, clientY } = e;
      const { innerWidth, innerHeight } = window;
      const offsetX = (clientX / innerWidth - 0.5) * 5;
      const offsetY = (clientY / innerHeight - 0.5) * 5;

      this.cards.forEach((div, index) => {
        const { randX, randY } = this.cardOffsets[index];

        gsap.to(div, {
          xPercent: randX + offsetX,
          yPercent: randY + offsetY,
          duration: 0.3,
          ease: "power2.out",
        });
      });
    }

    removeTransform() {
      this.cards.forEach((div) => {
        gsap.set(div, { clearProps: "transform", duration: 0.3 });
      });
    }

    removeParallax() {
      document.removeEventListener("mousemove", this.boundThrottleParallax);
    }

    checkScreenSize() {
      const screenWidth = window.innerWidth;

      if (screenWidth < 768) {
        this.removeParallax();
        this.removeTransform();
      } else {
        this.cardOffset();
        this.removeParallax(); // Prevent double binding
        document.addEventListener("mousemove", this.boundThrottleParallax);
      }
    }
  }

  const parallax = new ParallaxEffect(".home-card");
</script>
